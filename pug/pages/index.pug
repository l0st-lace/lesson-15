extends ../layouts/main-layout

block content
    main
        section.main-content
            .container-fluid
                .row
                    .col-xxl-7.col-xl-6.col-lg-6.col-mg-12
                        .hero-section.pb-5
                            h1.hero-title.text-white.m-0
                                | Удивительный мир
                                br
                                | Компьютерных игр
                            p.hero-desc.text-white.m-5
                                | Познакомьтесь с самыми популярными среди
                                br
                                | геймеров онлайн-играми. Узнайте что нового
                                br
                                | промсходит в виртуальном мире
                            a.btn.btn-purple.text-white(href='/') Узнать больше
                    .col-xxl-5.col-xl-6.col-lg-6.col-mg-12
                        .card-games.d-flex.flex-column
                            .first-card-row.d-flex.justify-content-between
                                .gta-img
                                    img(src='./img/gta.png' alt='')
                                .fortnite-img
                                    img(src='./img/fort.png' alt='')
                            .dota-img.mt-4
                                img(src='./img/dota.png' alt='')

